{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "MECA DRONE GCS",
  "version": "0.1.0",
  "identifier": "com.mecadrone.gcs",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3002"
  },
  "app": {
    "windows": [
      {
        "title": "MECA DRONE - Ground Control Station",
        "width": 1920,
        "height": 1080,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
